# =============================================================================
# GENERAL SETTINGS
# =============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# API Secret key for authentication
API_SECRET_KEY=your-secret-key-here

# Cloudflare Worker webhook URL (must match the worker's URL)
CLOUDFLARE_WORKER_URL=https://your-worker.your-subdomain.workers.dev

# =============================================================================
# DATABASE (Turso — recommended for production)
# =============================================================================

# Turso database URL (from: turso db show forwardr --url)
TURSO_DATABASE_URL=libsql://forwardr-yourusername.turso.io

# Turso auth token (from: turso db tokens create forwardr)
TURSO_AUTH_TOKEN=your-turso-auth-token

# Local SQLite fallback (used when Turso env vars are absent)
DATABASE_PATH=./forwardr.db

# =============================================================================
# MEDIA STORAGE
# =============================================================================

# Local media storage path
MEDIA_STORAGE_PATH=./media

# Maximum media file size in MB
MAX_MEDIA_SIZE_MB=50

# =============================================================================
# SCHEDULING
# =============================================================================

# Delay between posts in seconds (default: 3600 = 1 hour)
POST_DELAY_SECONDS=3600

# Maximum retry attempts for failed posts
MAX_RETRY_ATTEMPTS=3

# =============================================================================
# TELEGRAM
# =============================================================================

# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz # fake btw for testing

# Telegram Channel ID (format: @channel_name or -100123456789)
TELEGRAM_CHANNEL_ID=@your_channel

# Your Telegram user ID (numeric). Only this user can interact with the bot.
# Send a message to @userinfobot on Telegram to get your ID.
TELEGRAM_OWNER_ID=123456789

# Telegram API ID (from https://my.telegram.org)
TELEGRAM_API_ID=12345678

# Telegram API Hash (from https://my.telegram.org)
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# =============================================================================
# BLUESKY (AT PROTOCOL)
# =============================================================================

# Bluesky handle (e.g., username.bsky.social)
BLUESKY_HANDLE=your-handle.bsky.social

# Bluesky app password (create at https://bsky.app/settings/app-passwords)
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# =============================================================================
# MASTODON
# =============================================================================

# Mastodon instance URL (e.g., https://mastodon.social)
MASTODON_INSTANCE_URL=https://mastodon.social

# Mastodon access token (create in Settings > Development > New Application)
MASTODON_ACCESS_TOKEN=your-access-token-here

# =============================================================================
# INSTAGRAM (Graph API — Professional Account)
# =============================================================================

# Setup:
# 1. Connect your Instagram Professional account to a Facebook Page
# 2. Create a Facebook App at https://developers.facebook.com
# 3. Add Instagram Graph API product and request permissions:
#    instagram_basic, instagram_content_publish, pages_read_engagement
# 4. Generate a long-lived access token (valid ~60 days)
# 5. Get your Instagram Business Account ID via:
#    GET /me/accounts → page_id → GET /{page_id}?fields=instagram_business_account

# Instagram Graph API long-lived access token
INSTAGRAM_ACCESS_TOKEN=your_access_token

# Instagram Business/Creator Account ID (numeric)
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_business_account_id


# =============================================================================
# THREADS
# =============================================================================

# Threads access token (Graph API)
THREADS_ACCESS_TOKEN=your-threads-access-token

# Threads user ID
THREADS_USER_ID=your-threads-user-id

# =============================================================================
# TWITTER/X
# =============================================================================

# Twitter API v2 credentials (from https://developer.twitter.com)
TWITTER_API_KEY=your-api-key
TWITTER_API_SECRET=your-api-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret

# Twitter Bearer Token (for API v2)
TWITTER_BEARER_TOKEN=your-bearer-token

# =============================================================================
# REDDIT
# =============================================================================

# Reddit application credentials (from https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your-client-id
REDDIT_CLIENT_SECRET=your-client-secret

# Reddit account credentials
REDDIT_USERNAME=your_username
REDDIT_PASSWORD=your_password

# Reddit user agent (format: platform:app_name:version (by /u/username))
REDDIT_USER_AGENT=linux:forwardr:v1.0.0 (by /u/your_username)

# Target subreddit (without r/)
REDDIT_SUBREDDIT=your_subreddit

# Default title when caption is empty
REDDIT_DEFAULT_TITLE=Forwardr update

# =============================================================================
# YOUTUBE
# =============================================================================

# YouTube client secrets JSON file (from https://console.cloud.google.com)
YOUTUBE_CLIENT_SECRETS_FILE=./youtube_client_secrets.json

# YouTube OAuth2 token file path
YOUTUBE_TOKEN_FILE=./youtube_token.json

# =============================================================================
# CLOUDINARY (OPTIONAL - for Threads media uploads and cloud storage)
# =============================================================================

# Cloudinary provides public URLs for media, required for posting images/videos to Threads
# Setup:
# 1. Sign up at https://cloudinary.com/ (free tier available)
# 2. Get your credentials from the dashboard
# 3. Add the three credentials below
# Note: Without Cloudinary, Threads posts will be text-only

# Cloudinary cloud name
CLOUDINARY_CLOUD_NAME=your-cloud-name

# Cloudinary API key
CLOUDINARY_API_KEY=your-api-key

# Cloudinary API secret
CLOUDINARY_API_SECRET=your-api-secret

# =============================================================================
# LOGGING
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE_PATH=./logs/forwardr.log
